# Lumive AI — environment variables. Copy to .env.local and fill in.
# Everything is optional for local dev; the app degrades to brand-safe fallbacks.

# ── LLM brain (shared by web chat + WhatsApp agent) ──
# Set ONE of these to enable real AI replies. Without a key, both surfaces use a
# safe canned/engine fallback (never invents pricing or services).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Lumi — the public site chat widget — uses OpenRouter (model google/gemma-4-31b-it).
# Without this key the widget still works but replies with a brand-safe fallback
# that points visitors to /book.
OPENROUTER_API_KEY=

# ── WhatsApp Cloud API (Meta) ──
# From Meta for Developers → your WhatsApp app.
WHATSAPP_VERIFY_TOKEN=         # any string; paste the same value in the Meta webhook UI
WHATSAPP_TOKEN=               # permanent access token
WHATSAPP_PHONE_NUMBER_ID=     # Cloud API phone number id (NOT the phone number)
WHATSAPP_APP_SECRET=          # Meta app secret — verifies X-Hub-Signature-256
WHATSAPP_GRAPH_VERSION=v21.0

# Scheduling link the agent shares with hot leads.
BOOKING_URL=https://lumive.ai/#book

# ── Contact form lead capture (/api/contact) ──
# Forwarded through the first one set; otherwise logged server-side.
# 1) Any webhook (Zapier / Make / CRM intake):
# LEAD_WEBHOOK_URL=
# 2) Or email via Resend:
# RESEND_API_KEY=
# LEAD_TO_EMAIL=hello@lumive.ai
# LEAD_FROM_EMAIL=Lumive AI <onboarding@resend.dev>

# ── Crypto checkout for /book (NOWPayments) ──
# Create at nowpayments.io. Without NOWPAYMENTS_API_KEY the /book page degrades to
# the static wallet below (manual verification). The IPN webhook
# (/api/webhook/nowpayments) only fires once deployed to a public URL — register
# that URL in the NOWPayments dashboard (or it is passed via NEXT_PUBLIC_SITE_URL).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NEXT_PUBLIC_WALLET_ADDRESS=    # USDT-TRC20 receive address (fallback + payout)
CONSULTATION_PRICE_USD=50
# NEXT_PUBLIC_SITE_URL=https://lumive.ai   # public base URL for the IPN callback

# ── Cal.com scheduling (the /book flow) ──
# API key from cal.com → Settings → Developer → API keys. CAL_EVENT_TYPE_SLUG is
# matched by normalized slug OR title, so "30-min-meeting" resolves the "30 min
# meeting" event even though its real slug is "30min". Without a key, /book's
# calendar shows a friendly "scheduling unavailable" state.
CAL_API_KEY=
CAL_EVENT_TYPE_SLUG=30-min-meeting
# BUSINESS_TZ=Europe/Istanbul   # timezone used in booking confirmation emails

# ── Optional integrations (no-op until set) ──
# CRM_API_KEY=
# CRM_WEBHOOK_URL=
